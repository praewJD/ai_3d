# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# Application
# ============================================================
APP_NAME=Autonomous Creator
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///data/autonomous_creator.db

# Paths
OUTPUT_DIR=outputs
MODELS_DIR=models

# ============================================================
# 🎨 스타일 설정 (3D 애니메이션 기본)
# ============================================================
# 기본 아트 스타일: anime_3d, anime_2d, realistic, cartoon, watercolor
DEFAULT_ART_STYLE=anime_3d

# 3D 애니메이션 세부 설정
ANIME_3D_LIGHTING=soft_studio
ANIME_3D_RENDER_QUALITY=high
ANIME_3D_SHADER=cel_shaded

# 이미지 생성 기본 설정
IMAGE_DEFAULT_STYLE_PREFIX=3D anime style, Pixar quality, smooth shading
IMAGE_NEGATIVE_PROMPT=realistic, photo, live action, western style, rough

# ============================================================
# 💰 비용 최적화 설정
# ============================================================
# 비디오 생성 전략: all_api, key_scenes_api, smart_hybrid, local_first
VIDEO_GENERATION_STRATEGY=key_scenes_api

# 핵심 장면 비율 (0.0~1.0, key_scenes_api 전략용)
KEY_SCENE_RATIO=0.3

# 월간 API 예산 (USD)
MONTHLY_BUDGET_USD=100.0

# 예산 초과 시 자동 로컬 전환
AUTO_COST_SAVING=true

# API 사용량 경고 임계값 (0.0~1.0)
API_USAGE_WARNING_THRESHOLD=0.8

# ============================================================
# LLM API
# ============================================================
# GLM API (Zhipu AI) - SceneGraph 생성용 (추천)
GLM_API_KEY=your_glm_api_key_here
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash
GLM_MAX_TOKENS=4096

# Claude API (프롬프트 생성, 스크립트 작성)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# OpenAI API (백업)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================================
# Video Generation API
# ============================================================
# Luma Dream Machine API
LUMA_API_KEY=your_luma_api_key_here
LUMA_DEFAULT_MODEL=kling-2.6
LUMA_DEFAULT_RESOLUTION=1080p
LUMA_DEFAULT_DURATION=5

# Runway API (선택)
RUNWAY_API_KEY=your_runway_api_key_here
RUNWAY_DEFAULT_MODEL=gen-3-alpha

# Kling AI API (선택)
KLING_API_KEY=your_kling_api_key_here

# ============================================================
# TTS Settings
# ============================================================
GPT_SOVITS_URL=http://localhost:9872
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_REGION=southeastasia

# ElevenLabs (선택)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ============================================================
# Image Generation (Local)
# ============================================================
SD_MODEL=stabilityai/stable-diffusion-3.5-medium
SD_DEVICE=cuda
SD_LOW_VRAM=false

# Stability AI API (클라우드 사용시)
STABILITY_API_KEY=your_stability_api_key_here

# ============================================================
# Video Settings
# ============================================================
VIDEO_RESOLUTION=1080x1920
VIDEO_FPS=30
VIDEO_QUALITY=fhd

# SVD Settings (로컬)
SVD_ENABLED=true
SVD_MODEL=stabilityai/stable-video-diffusion-img2vid-xt-1-1
SVD_VRAM_REQUIRED=12

# ============================================================
# API 공통 설정
# ============================================================
API_TIMEOUT=120
API_MAX_RETRIES=3
API_RETRY_BACKOFF=2.0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_SECOND=10

# ============================================================
# 로컬 모델 설정
# ============================================================
USE_LOCAL_MODELS=true

# ============================================================
# IP-Adapter 설정 (캐릭터 일관성)
# ============================================================
IP_ADAPTER_ENABLED=true
IP_ADAPTER_MODEL_PATH=models/ip-adapter
IP_ADAPTER_STRENGTH=0.8

# 캐릭터 캐시
CHARACTER_CACHE_DIR=data/character_cache
CHARACTER_CACHE_ENABLED=true

# 장소 DB
LOCATION_DB_DIR=data/locations
